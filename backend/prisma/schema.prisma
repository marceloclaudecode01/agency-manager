generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  LEAD
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BudgetStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum EventType {
  MEETING
  DEADLINE
  DELIVERY
  OTHER
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(MEMBER)
  avatar       String?
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks            Task[]
  calendarEvents   CalendarEvent[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications    Notification[]

  @@map("users")
}

model Message {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  taskId    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Client {
  id                  String       @id @default(cuid())
  name                String
  email               String?
  phone               String?
  company             String?
  status              ClientStatus @default(LEAD)
  notes               String?
  // Social media page config (multi-page support)
  facebookPageId      String?
  facebookAccessToken String?
  facebookPageName    String?
  niche               String?      // ex: "telecom", "tv_online", "ecommerce"
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  campaigns      Campaign[]
  budgets        Budget[]
  invoices       Invoice[]
  scheduledPosts ScheduledPost[]
  strategies     WeeklyStrategy[]

  @@map("clients")
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  clientId    String
  status      CampaignStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  goals       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks          Task[]
  budgets        Budget[]
  calendarEvents CalendarEvent[]

  @@map("campaigns")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  campaignId  String?
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignee User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

model Budget {
  id         String       @id @default(cuid())
  title      String
  clientId   String
  campaignId String?
  items      Json         @default("[]")
  total      Float        @default(0)
  status     BudgetStatus @default(DRAFT)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@map("budgets")
}

model Invoice {
  id        String        @id @default(cuid())
  clientId  String
  budgetId  String?
  amount    Float
  status    InvoiceStatus @default(PENDING)
  dueDate   DateTime?
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget Budget? @relation(fields: [budgetId], references: [id], onDelete: SetNull)

  @@map("invoices")
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType @default(OTHER)
  date        DateTime
  endDate     DateTime?
  campaignId  String?
  userId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("calendar_events")
}

enum ScheduledPostStatus {
  PENDING
  PENDING_VIDEO
  APPROVED
  REJECTED
  PUBLISHED
  FAILED
}

model ScheduledPost {
  id              String              @id @default(cuid())
  topic           String
  message         String
  hashtags        String?
  imageUrl        String?
  platform        String?             @default("facebook")
  scheduledFor    DateTime
  status          ScheduledPostStatus @default(PENDING)
  publishedAt     DateTime?
  retryCount      Int                 @default(0)
  timezone        String?
  nativeScheduled Boolean             @default(false)
  metaPostId      String?
  source          String?
  contentType     String?
  governorDecision    String?
  governorReason      String?
  governorReviewedAt  DateTime?
  qualityScore        Int?
  abTestId            String?
  viralScore          Int?
  viralEnhancements   Json?
  carouselData        Json?
  videoUrl            String?
  comfyRunId          String?
  clientId        String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status, scheduledFor])
  @@map("scheduled_posts")
}

model CommentLog {
  id        String   @id @default(cuid())
  commentId String   @unique
  action    String
  reply     String
  sentiment String?  // POSITIVE | NEUTRAL | NEGATIVE | CRISIS
  createdAt DateTime @default(now())

  @@map("comment_logs")
}

model MetricsReport {
  id                String   @id @default(cuid())
  summary           String
  highlights        Json
  recommendations   Json
  bestPostingTimes  Json
  growthScore       Int
  engagementScore   Int?
  commercialScore   Int?
  riskScore         Int?
  rawData           Json
  createdAt         DateTime @default(now())

  @@map("metrics_reports")
}

enum ProductCampaignStatus {
  PENDING
  SCHEDULED
  PUBLISHED
  PAUSED
}

model ProductCampaign {
  id              String                @id @default(cuid())
  title           String
  productUrl      String
  imageUrl        String
  productName     String?
  productPrice    String?
  productDesc     String?
  sourceDomain    String?
  generatedCopy   String?
  hashtags        String?
  scheduledPostId String?
  status          ProductCampaignStatus @default(PENDING)
  autoReply       Boolean               @default(true)
  replyTemplate   String?
  fbPostId        String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("product_campaigns")
}

model WeeklyStrategy {
  id               String   @id @default(cuid())
  weekStart        DateTime
  maxPostsPerDay   Int      @default(5)
  contentMix       Json
  bestPostingHours Json
  adjustmentReason String
  clientId         String?
  createdAt        DateTime @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@map("weekly_strategies")
}

model TrendingCache {
  id          String   @id @default(cuid())
  trends      Json
  generatedAt DateTime
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("trending_cache")
}

model AgentLog {
  id        String   @id @default(cuid())
  from      String   // nome do agente que enviou
  to        String?  // nome do agente destinatário (null = broadcast/sistema)
  type      String   // "info" | "action" | "result" | "error" | "communication"
  message   String
  payload   Json?    // dados extras opcionais
  agentId   String?  // FK to Agent (optional, for future use)
  createdAt DateTime @default(now())

  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@map("agent_logs")
}

// Phase 1: System Sentinel + Safe Mode
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// Phase 3: Feedback Loop de Performance
model ContentPerformance {
  id              String   @id @default(cuid())
  postId          String
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  engagementScore Float    @default(0)
  contentType     String?
  topic           String?
  publishedHour   Int?
  createdAt       DateTime @default(now())

  @@map("content_performance")
}

// Phase 4: Brand Brain
model BrandConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("brand_config")
}

// Epic 1: A/B Testing
model ABTest {
  id            String   @id @default(cuid())
  originalTopic String
  variantA      String   // ScheduledPost ID
  variantB      String   // ScheduledPost ID
  status        String   @default("RUNNING") // RUNNING | COMPLETED | CANCELLED
  winnerId      String?  // ID do post vencedor
  winnerReason  String?
  scoreA        Float    @default(0)
  scoreB        Float    @default(0)
  measuredAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("ab_tests")
}

// Epic 2: Content Replicas (multi-formato)
model ContentReplica {
  id              String   @id @default(cuid())
  originalPostId  String
  format          String   // carousel | story | video_script | email | thread | ad_copy
  platform        String   // facebook | instagram | tiktok | youtube | email
  content         String   // texto principal
  slides          Json?    // array de slides (para carousel)
  metadata        Json?    // dados extras (duração, dimensões, etc)
  status          String   @default("DRAFT") // DRAFT | READY | PUBLISHED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("content_replicas")
}

// Epic 1: Reputation Monitor
model ReputationEvent {
  id        String   @id @default(cuid())
  type      String   // NEGATIVE_FEEDBACK | HIDE | REPORT | ENGAGEMENT_DROP | UNLIKE
  severity  String   @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL
  details   String
  actionTaken String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("reputation_events")
}

// Epic 3: Lead Acquisition + CRM
model Lead {
  id          String   @id @default(cuid())
  name        String?
  source      String   // comment | dm | form | manual
  sourceId    String?  // comment ID or post ID
  email       String?
  phone       String?
  stage       String   @default("NEW") // NEW | CONTACTED | QUALIFIED | PROPOSAL | WON | LOST
  score       Int      @default(0)
  notes       String?
  lastContact DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  interactions LeadInteraction[]

  @@map("leads")
}

model LeadInteraction {
  id        String   @id @default(cuid())
  leadId    String
  type      String   // comment_reply | dm | email | call | note
  content   String
  direction String   @default("OUTBOUND") // INBOUND | OUTBOUND
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_interactions")
}

// Epic 4: Monetization Engine
model Funnel {
  id          String   @id @default(cuid())
  name        String
  type        String   // awareness | consideration | conversion | retention
  steps       Json     // array of step objects
  conversionRate Float @default(0)
  status      String   @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offers Offer[]

  @@map("funnels")
}

model Offer {
  id          String   @id @default(cuid())
  funnelId    String?
  name        String
  type        String   // product | service | lead_magnet | upsell
  price       Float?
  description String?
  ctaUrl      String?
  conversions Int      @default(0)
  impressions Int      @default(0)
  revenue     Float    @default(0)
  status      String   @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  funnel Funnel? @relation(fields: [funnelId], references: [id], onDelete: SetNull)

  @@map("offers")
}

// Epic 5: Strategic Command AI
model StrategicPlan {
  id              String   @id @default(cuid())
  period          String   // "2026-03" format
  goals           Json     // array of goal objects
  tactics         Json     // array of tactic objects
  kpis            Json     // key metrics to track
  budgetAlloc     Json?    // budget allocation per channel
  competitorNotes String?
  status          String   @default("ACTIVE") // ACTIVE | SUPERSEDED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("strategic_plans")
}

// Epic 6: Market Intelligence
model MarketIntel {
  id        String   @id @default(cuid())
  type      String   // competitor | trend | opportunity | threat
  title     String
  summary   String
  details   Json?
  source    String?  // web | social | manual
  relevance Int      @default(5) // 1-10
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@map("market_intel")
}

// Epic 7: Niche Learning Engine
model AudienceInsight {
  id          String   @id @default(cuid())
  category    String   // demographics | behavior | preference | pain_point | desire
  insight     String
  confidence  Float    @default(0.5) // 0-1
  dataPoints  Int      @default(1)
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("audience_insights")
}

// Epic 8: Paid Traffic War Machine
model AdCampaign {
  id            String   @id @default(cuid())
  name          String
  platform      String   @default("meta") // meta | google | tiktok
  objective     String   // awareness | traffic | conversions | leads
  budget        Float    @default(0)
  spent         Float    @default(0)
  status        String   @default("DRAFT") // DRAFT | ACTIVE | PAUSED | COMPLETED
  metaCampaignId String?
  startDate     DateTime?
  endDate       DateTime?
  results       Json?    // impressions, clicks, conversions, cpa, roas
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creatives AdCreative[]

  @@map("ad_campaigns")
}

model AdCreative {
  id           String   @id @default(cuid())
  campaignId   String
  type         String   // image | video | carousel | story
  headline     String
  body         String
  ctaText      String?
  mediaUrl     String?
  performance  Json?    // ctr, cpc, conversions
  status       String   @default("DRAFT") // DRAFT | ACTIVE | PAUSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ad_creatives")
}

// Agent Registry (persistent, single source of truth)
model Agent {
  id              String   @id @default(cuid())
  name            String   @unique
  function        String   // maps to AGENT_FUNCTION_MAP key
  description     String?  // specialty
  status          String   @default("active") // active | paused | error
  autonomyLevel   Int      @default(5) // 1=interactive, 3=supervised, 5=full
  cronExpression  String?  // null = on-demand/inline
  lastRunAt       DateTime?
  errorCount      Int      @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  logs AgentLog[]
  performances AgentPerformance[]

  @@map("agents")
}

// Orion Strategic: Agent Performance Tracking
model AgentPerformance {
  id             String   @id @default(cuid())
  agentId        String
  successRate    Float    @default(100)
  errorCount     Int      @default(0)
  totalExecs     Int      @default(0)
  avgDurationMs  Float    @default(0)
  lastExecAt     DateTime?
  classification String   @default("STABLE") // HIGH_PERFORMER | STABLE | LOW_PERFORMER | CRITICAL
  impactScore    Float    @default(50) // 0-100
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId])
  @@map("agent_performance")
}

// Orion Strategic: System Evaluation Snapshots
model StrategicReport {
  id              String   @id @default(cuid())
  healthScore     Float    @default(0) // 0-100
  confidenceLevel String   @default("LOW") // LOW | MEDIUM | HIGH
  totalAgents     Int      @default(0)
  classifications Json     // { HIGH_PERFORMER: n, STABLE: n, LOW_PERFORMER: n, CRITICAL: n }
  agentDetails    Json     // array of { name, classification, successRate, autonomyLevel }
  evolutionActions Json?   // actions taken by evolution engine
  createdAt       DateTime @default(now())

  @@map("strategic_reports")
}

// Phase 8: Content Campaigns
model ContentCampaign {
  id           String   @id @default(cuid())
  name         String
  type         String   // "seasonal" | "launch" | "awareness" | "engagement"
  startDate    DateTime
  endDate      DateTime
  priority     Int      @default(5)
  contentRules Json     // { requiredTopics, forbiddenTopics, toneOverride, etc }
  status       String   @default("ACTIVE") // ACTIVE | PAUSED | COMPLETED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("content_campaigns")
}
