# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agency_db

# Auth
JWT_SECRET=your-jwt-secret-here
REFRESH_TOKEN_SECRET=your-refresh-secret-here

# Server
PORT=3333
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Facebook / Meta
FACEBOOK_ACCESS_TOKEN=your-page-access-token-here
FACEBOOK_PAGE_ID=your-page-id-here

# Groq AI (used by gemini.ts — despite the name, uses Groq SDK)
GROQ_API_KEY=your-groq-api-key-here

# TikTok Shop
SCRAPECREATORS_API_KEY=your-scrapecreators-api-key-here

# Seed passwords (optional — defaults to dev passwords if not set)
SEED_ADMIN_PASSWORD=
SEED_MANAGER_PASSWORD=
SEED_MEMBER_PASSWORD=
